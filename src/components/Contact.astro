---
import SectionTitle from "./SectionTitle.astro";
import { site } from "../config/site";

const socialItems = [
  {
    name: "Facebook",
    href: site.social.facebook,
    icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/></svg>`,
    handle: "@lumenfideiradio",
  },
  {
    name: "Instagram",
    href: site.social.instagram,
    icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><circle cx="12" cy="12" r="4"/><circle cx="17.5" cy="6.5" r="0.5" fill="currentColor"/></svg>`,
    handle: "@lumenfideiradio",
  },
  {
    name: "YouTube",
    href: site.social.youtube,
    icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M22.54 6.42a2.78 2.78 0 0 0-1.95-1.96C18.88 4 12 4 12 4s-6.88 0-8.59.46a2.78 2.78 0 0 0-1.95 1.96A29 29 0 0 0 1 12a29 29 0 0 0 .46 5.58A2.78 2.78 0 0 0 3.41 19.6C5.12 20 12 20 12 20s6.88 0 8.59-.46a2.78 2.78 0 0 0 1.95-1.95A29 29 0 0 0 23 12a29 29 0 0 0-.46-5.58zM9.75 15.02V8.98L15.5 12l-5.75 3.02z"/></svg>`,
    handle: "@lumenfideiradio",
  },
  {
    name: "WhatsApp",
    href: site.social.whatsapp,
    icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413z"/></svg>`,
    handle: "Escríbenos",
  },
].filter((s) => s.href);
---

<section id="contacto" class="py-24 lg:py-32 relative">
  <div class="absolute inset-0 pointer-events-none" aria-hidden="true">
    <div
      class="absolute bottom-0 right-1/4 w-[350px] h-[350px] rounded-full blur-3xl opacity-40"
      style="background: radial-gradient(circle, rgba(233,179,58,0.07) 0%, transparent 70%);"
    ></div>
  </div>

  <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-20 items-start">
      <!-- Left: info -->
      <div>
        <SectionTitle
          eyebrow="Contacto"
          title="Estamos para escucharte"
          subtitle="¿Tienes una petición de oración, una sugerencia o quieres ser parte de nuestra comunidad? Escríbenos."
        />

        <div class="mt-8 space-y-4">
          <!-- Email -->
          <a
            href={`mailto:${site.contact.email}`}
            class="contact-item flex items-center gap-4 p-4 rounded-xl transition-all duration-200"
            style="background-color: var(--bg-card); border: 1px solid var(--border);"
          >
            <div
              class="w-10 h-10 rounded-lg flex items-center justify-center flex-shrink-0"
              style="background-color: var(--gold-dim); color: var(--gold);"
              aria-hidden="true"
            >
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
                <polyline points="22,6 12,13 2,6"/>
              </svg>
            </div>
            <div>
              <p class="text-xs mb-0.5" style="color: var(--text-muted);">Correo electrónico</p>
              <p class="text-sm font-medium" style="color: var(--text-primary);">{site.contact.email}</p>
            </div>
            <svg class="ml-auto flex-shrink-0" xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="color: var(--text-muted);" aria-hidden="true">
              <line x1="5" y1="12" x2="19" y2="12"/>
              <polyline points="12,5 19,12 12,19"/>
            </svg>
          </a>

          {
            site.contact.phone && (
              <a
                href={`tel:${site.contact.phone.replace(/\s/g, "")}`}
                class="contact-item flex items-center gap-4 p-4 rounded-xl transition-all duration-200"
                style="background-color: var(--bg-card); border: 1px solid var(--border);"
              >
                <div
                  class="w-10 h-10 rounded-lg flex items-center justify-center flex-shrink-0"
                  style="background-color: var(--gold-dim); color: var(--gold);"
                  aria-hidden="true"
                >
                  <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 13a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.6 2.18h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 9.91a16 16 0 0 0 6 6l.91-.91a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 21.73 17z"/>
                  </svg>
                </div>
                <div>
                  <p class="text-xs mb-0.5" style="color: var(--text-muted);">Teléfono</p>
                  <p class="text-sm font-medium" style="color: var(--text-primary);">{site.contact.phone}</p>
                </div>
                <svg class="ml-auto flex-shrink-0" xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="color: var(--text-muted);" aria-hidden="true">
                  <line x1="5" y1="12" x2="19" y2="12"/>
                  <polyline points="12,5 19,12 12,19"/>
                </svg>
              </a>
            )
          }

          <!-- Transmisión -->
          <div
            class="flex items-center gap-4 p-4 rounded-xl"
            style="background-color: var(--bg-card); border: 1px solid var(--border);"
          >
            <div
              class="w-10 h-10 rounded-lg flex items-center justify-center flex-shrink-0"
              style="background-color: var(--gold-dim); color: var(--gold);"
              aria-hidden="true"
            >
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M1 6l11 6 11-6"/>
                <path d="M1 12l11 6 11-6"/>
              </svg>
            </div>
            <div>
              <p class="text-xs mb-0.5" style="color: var(--text-muted);">Transmisión FM</p>
              <p class="text-sm font-medium" style="color: var(--text-primary);">{site.frequency} · Streaming 24/7</p>
            </div>
          </div>
        </div>
      </div>

      <!-- Right: social links -->
      <div>
        <p class="text-xs font-semibold uppercase tracking-widest mb-6" style="color: var(--text-muted);">
          Síguenos en redes
        </p>

        <div class="grid grid-cols-1 gap-3">
          {
            socialItems.map((social) => (
              <a
                href={social.href}
                target="_blank"
                rel="noopener noreferrer"
                class="social-card flex items-center gap-4 p-4 rounded-2xl transition-all duration-200"
                style="background-color: var(--bg-card); border: 1px solid var(--border);"
                aria-label={`Seguir en ${social.name}`}
              >
                <div
                  class="w-10 h-10 rounded-xl flex items-center justify-center flex-shrink-0"
                  style="background-color: var(--gold-dim); color: var(--gold);"
                  set:html={social.icon}
                />
                <div>
                  <p class="text-sm font-semibold" style="color: var(--text-primary);">{social.name}</p>
                  <p class="text-xs" style="color: var(--text-muted);">{social.handle}</p>
                </div>
                <svg class="ml-auto flex-shrink-0" xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="color: var(--text-muted);" aria-hidden="true">
                  <line x1="7" y1="17" x2="17" y2="7"/>
                  <polyline points="7,7 17,7 17,17"/>
                </svg>
              </a>
            ))
          }
        </div>

        <!-- CTA email block -->
        <div
          class="mt-6 p-6 rounded-2xl text-center"
          style="background: linear-gradient(135deg, var(--gold-dim) 0%, transparent 100%); border: 1px solid rgba(233,179,58,0.2);"
        >
          <p class="text-sm font-semibold mb-1" style="color: var(--text-primary);">¿Petición de oración?</p>
          <p class="text-xs mb-4" style="color: var(--text-muted);">Escríbenos y toda nuestra comunidad orará contigo.</p>
          <a
            href={`mailto:${site.contact.email}?subject=Petición de oración`}
            class="inline-flex items-center gap-2 px-5 py-2.5 rounded-xl text-sm font-semibold transition-all duration-200"
            style="background-color: var(--gold); color: #0a0a0a;"
          >
            Enviar petición
          </a>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .contact-item:hover {
    border-color: var(--border-hover) !important;
    background-color: var(--bg-card-hover) !important;
  }
  .social-card:hover {
    border-color: var(--gold) !important;
    background-color: var(--bg-card-hover) !important;
    transform: translateX(4px);
  }
  a[style*="background-color: var(--gold)"]:hover {
    opacity: 0.9;
    box-shadow: 0 4px 16px var(--gold-glow);
  }
</style>
