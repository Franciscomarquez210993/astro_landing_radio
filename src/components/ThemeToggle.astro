---
// Client island — handles dark/light toggle
---

<button
  id="theme-toggle"
  aria-label="Alternar tema claro/oscuro"
  class="relative flex items-center justify-center w-9 h-9 rounded-lg border transition-colors duration-200 cursor-pointer"
  style="border-color: var(--border); color: var(--text-secondary);"
>
  <!-- Sun icon -->
  <svg
    id="icon-sun"
    xmlns="http://www.w3.org/2000/svg"
    width="18"
    height="18"
    viewBox="0 0 24 24"
    fill="none"
    stroke="currentColor"
    stroke-width="2"
    stroke-linecap="round"
    stroke-linejoin="round"
    class="hidden"
    aria-hidden="true"
  >
    <circle cx="12" cy="12" r="4"></circle>
    <path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M6.34 17.66l-1.41 1.41M19.07 4.93l-1.41 1.41"
    ></path>
  </svg>
  <!-- Moon icon -->
  <svg
    id="icon-moon"
    xmlns="http://www.w3.org/2000/svg"
    width="18"
    height="18"
    viewBox="0 0 24 24"
    fill="none"
    stroke="currentColor"
    stroke-width="2"
    stroke-linecap="round"
    stroke-linejoin="round"
    aria-hidden="true"
  >
    <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"></path>
  </svg>
</button>

<script>
  function initTheme() {
    const stored = localStorage.getItem("theme");
    // Default is always dark unless user explicitly switched to light
    applyTheme(stored === "light" ? "light" : "dark");
  }

  function applyTheme(theme: string) {
    const html = document.documentElement;
    const sun = document.getElementById("icon-sun");
    const moon = document.getElementById("icon-moon");

    if (theme === "light") {
      html.classList.add("light");
      sun?.classList.remove("hidden");
      moon?.classList.add("hidden");
    } else {
      html.classList.remove("light");
      sun?.classList.add("hidden");
      moon?.classList.remove("hidden");
    }
  }

  initTheme();

  document.getElementById("theme-toggle")?.addEventListener("click", () => {
    const isLight = document.documentElement.classList.contains("light");
    const next = isLight ? "dark" : "light";
    localStorage.setItem("theme", next);
    applyTheme(next);
  });
</script>
