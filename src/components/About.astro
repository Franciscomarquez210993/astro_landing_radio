---
import SectionTitle from "./SectionTitle.astro";
import { site } from "../config/site";

const values = [
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>`,
    title: "Fe",
    description: "Transmitimos la Palabra con fidelidad a la enseñanza de la Iglesia Católica.",
  },
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>`,
    title: "Familia",
    description: "Un espacio de encuentro para familias que buscan crecer en la fe juntos.",
  },
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><path d="M8.56 2.75c4.37 6.03 6.02 9.42 8.03 17.72m2.54-15.38c-3.72 4.35-8.94 5.66-16.88 5.85m19.5 1.9c-3.5-.93-6.63-.82-8.94 0-2.58.92-5.01 2.86-7.44 6.32"/></svg>`,
    title: "Comunidad",
    description: "Unidos en la oración y la escucha, formamos una comunidad de oyentes fieles.",
  },
];
---

<section id="acerca" class="py-24 lg:py-32 relative overflow-hidden">
  <!-- Background glow -->
  <div class="absolute inset-0 pointer-events-none" aria-hidden="true">
    <div
      class="absolute bottom-0 left-0 w-[400px] h-[400px] rounded-full blur-3xl opacity-50"
      style="background: radial-gradient(circle, rgba(233,179,58,0.07) 0%, transparent 70%);"
    ></div>
  </div>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-20 items-center">
      <!-- Left: text -->
      <div>
        <div class="reveal">
          <SectionTitle
            eyebrow="Acerca"
            title="Una emisora nacida de la fe"
            subtitle="Somos una radio católica comprometida con la evangelización a través de las ondas."
          />
        </div>

        <div class="mt-8 space-y-4 text-base leading-relaxed reveal reveal-delay-1" style="color: var(--text-secondary);">
          <p>
            <strong style="color: var(--text-primary);">{site.name}</strong> nació con la misión de ser un faro de luz en el dial. Ofrecemos una programación que alimenta el espíritu, forma la conciencia y acompaña a nuestros oyentes en su camino de fe.
          </p>
          <p>
            Desde la Misa diaria hasta programas de formación, música sacra y testimonios de vida, cada hora de nuestra transmisión está pensada para acercar a las almas a Dios.
          </p>
        </div>

        <!-- Values -->
        <div class="mt-10 grid grid-cols-1 sm:grid-cols-3 gap-4">
          {
            values.map((v) => (
              <div
                class="value-card p-4 rounded-xl transition-all duration-200"
                style="background-color: var(--bg-card); border: 1px solid var(--border);"
              >
                <div
                  class="w-9 h-9 rounded-lg flex items-center justify-center mb-3"
                  style="background-color: var(--gold-dim); color: var(--gold);"
                  set:html={v.icon}
                />
                <h3 class="text-sm font-semibold mb-1" style="color: var(--text-primary);">{v.title}</h3>
                <p class="text-xs leading-relaxed" style="color: var(--text-muted);">{v.description}</p>
              </div>
            ))
          }
        </div>
      </div>

      <!-- Right: logo card -->
      <div class="flex justify-center lg:justify-end">
        <div
          class="relative w-72 h-72 lg:w-80 lg:h-80 rounded-3xl flex items-center justify-center"
          style="background-color: var(--bg-card); border: 1px solid var(--border);"
        >
          <!-- Corner accents -->
          <div class="absolute top-3 left-3 w-5 h-5 border-t-2 border-l-2 rounded-tl-lg" style="border-color: var(--gold);"></div>
          <div class="absolute top-3 right-3 w-5 h-5 border-t-2 border-r-2 rounded-tr-lg" style="border-color: var(--gold);"></div>
          <div class="absolute bottom-3 left-3 w-5 h-5 border-b-2 border-l-2 rounded-bl-lg" style="border-color: var(--gold);"></div>
          <div class="absolute bottom-3 right-3 w-5 h-5 border-b-2 border-r-2 rounded-br-lg" style="border-color: var(--gold);"></div>

          <!-- Glow behind logo -->
          <div
            class="absolute w-48 h-48 rounded-full blur-2xl"
            style="background: radial-gradient(circle, rgba(233,179,58,0.2) 0%, transparent 70%);"
          ></div>

          <img
            src="/logo.svg"
            alt={`Isotipo ${site.name}`}
            width="200"
            height="200"
            loading="lazy"
            class="relative w-44 h-44 object-contain drop-shadow-lg"
          />
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .value-card:hover {
    border-color: var(--border-hover) !important;
    background-color: var(--bg-card-hover) !important;
  }
</style>
