---
interface Props {
  eyebrow: string;
  title: string;
  subtitle?: string;
  center?: boolean;
}

const { eyebrow, title, subtitle, center = false } = Astro.props;
---

<div class={center ? "text-center max-w-2xl mx-auto" : "max-w-2xl"}>
  <p
    class="text-xs font-medium uppercase tracking-[0.2em] mb-3"
    style="color: var(--gold);"
  >
    {eyebrow}
  </p>
  <h2
    class="text-3xl sm:text-4xl lg:text-5xl font-bold leading-[1.1] mb-4 tracking-[-0.01em]"
    style="color: var(--text-primary);"
  >
    {title}
  </h2>
  {
    subtitle && (
      <p class="text-base sm:text-lg leading-relaxed" style="color: var(--text-secondary);">
        {subtitle}
      </p>
    )
  }
</div>
