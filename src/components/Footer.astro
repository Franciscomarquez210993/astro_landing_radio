---
import { site, whatsappLink } from "../config/site";

const currentYear = new Date().getFullYear();

const navLinks = [
  { href: "#inicio", label: "Inicio" },
  { href: "#acerca", label: "Acerca" },
  { href: "#programacion", label: "Programación" },
  { href: "#locutores", label: "Locutores" },
  { href: "#donativos", label: "Donativos" },
  { href: "#patrocinantes", label: "Patrocinantes" },
  { href: "#contacto", label: "Contacto" },
];
---

<footer
  class="relative mt-24 pt-16 pb-8"
  style="border-top: 1px solid var(--border);"
>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-12 mb-12">
      <!-- Brand -->
      <div class="md:col-span-1">
        <a href="#inicio" class="flex items-center gap-3 mb-4 group w-fit">
          <img
            src="/logo.svg"
            alt="Logo Lumen Fidei Radio"
            width="40"
            height="40"
            loading="lazy"
            class="w-10 h-10 object-contain transition-transform duration-300 group-hover:scale-105"
          />
          <div class="leading-none">
            <span
              class="block text-sm font-semibold"
              style="color: var(--text-primary);">{site.name}</span
            >
            <span class="block text-xs font-medium" style="color: var(--gold);"
              >{site.frequency}</span
            >
          </div>
        </a>
        <p class="text-sm leading-relaxed max-w-xs" style="color: var(--text-muted);">
          {site.tagline}
        </p>

        <!-- Social links -->
        <div class="flex items-center gap-3 mt-6">
          {
            site.social.facebook && (
              <a
                href={site.social.facebook}
                target="_blank"
                rel="noopener noreferrer"
                aria-label="Facebook"
                class="social-icon w-9 h-9 rounded-lg border flex items-center justify-center transition-all duration-200"
                style="border-color: var(--border); color: var(--text-muted);"
              >
                <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                  <path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z" />
                </svg>
              </a>
            )
          }
          {
            site.social.instagram && (
              <a
                href={site.social.instagram}
                target="_blank"
                rel="noopener noreferrer"
                aria-label="Instagram"
                class="social-icon w-9 h-9 rounded-lg border flex items-center justify-center transition-all duration-200"
                style="border-color: var(--border); color: var(--text-muted);"
              >
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <rect x="2" y="2" width="20" height="20" rx="5" ry="5" />
                  <circle cx="12" cy="12" r="4" />
                  <circle cx="17.5" cy="6.5" r="0.5" fill="currentColor" />
                </svg>
              </a>
            )
          }
          {
            site.social.youtube && (
              <a
                href={site.social.youtube}
                target="_blank"
                rel="noopener noreferrer"
                aria-label="YouTube"
                class="social-icon w-9 h-9 rounded-lg border flex items-center justify-center transition-all duration-200"
                style="border-color: var(--border); color: var(--text-muted);"
              >
                <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                  <path d="M22.54 6.42a2.78 2.78 0 0 0-1.95-1.96C18.88 4 12 4 12 4s-6.88 0-8.59.46a2.78 2.78 0 0 0-1.95 1.96A29 29 0 0 0 1 12a29 29 0 0 0 .46 5.58A2.78 2.78 0 0 0 3.41 19.6C5.12 20 12 20 12 20s6.88 0 8.59-.46a2.78 2.78 0 0 0 1.95-1.95A29 29 0 0 0 23 12a29 29 0 0 0-.46-5.58zM9.75 15.02V8.98L15.5 12l-5.75 3.02z"/>
                </svg>
              </a>
            )
          }
          {
            site.contact.whatsappNumber && (
              <a
                href={whatsappLink(site.ctaMessages.greeting)}
                target="_blank"
                rel="noopener noreferrer"
                aria-label="Escríbenos por WhatsApp"
                class="social-icon w-9 h-9 rounded-lg border flex items-center justify-center transition-all duration-200"
                style="border-color: var(--border); color: var(--text-muted);"
              >
                <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                  <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413z"/>
                </svg>
              </a>
            )
          }
        </div>
      </div>

      <!-- Navigation -->
      <div>
        <h3 class="text-xs font-semibold uppercase tracking-widest mb-4" style="color: var(--text-muted);">
          Navegación
        </h3>
        <ul class="flex flex-col gap-2">
          {
            navLinks.map((link) => (
              <li>
                <a
                  href={link.href}
                  class="text-sm transition-colors duration-200"
                  style="color: var(--text-secondary);"
                >
                  {link.label}
                </a>
              </li>
            ))
          }
        </ul>
      </div>

      <!-- Contact -->
      <div>
        <h3 class="text-xs font-semibold uppercase tracking-widest mb-4" style="color: var(--text-muted);">
          Contacto
        </h3>
        <ul class="flex flex-col gap-3">
          <li>
            <a
              href={`mailto:${site.contact.email}`}
              class="text-sm flex items-center gap-2 transition-colors duration-200"
              style="color: var(--text-secondary);"
            >
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
                <polyline points="22,6 12,13 2,6"/>
              </svg>
              {site.contact.email}
            </a>
          </li>
          {
            site.contact.phone && (
              <li>
                <a
                  href={`tel:${site.contact.phone.replace(/\s/g, "")}`}
                  class="text-sm flex items-center gap-2 transition-colors duration-200"
                  style="color: var(--text-secondary);"
                >
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 13a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.6 2.18h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 9.91a16 16 0 0 0 6 6l.91-.91a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 21.73 17z"/>
                  </svg>
                  {site.contact.phone}
                </a>
              </li>
            )
          }
          <li>
            <span
              class="text-sm flex items-center gap-2"
              style="color: var(--text-muted);"
            >
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <circle cx="12" cy="12" r="10"/>
                <polyline points="12,6 12,12 16,14"/>
              </svg>
              Transmisión 24/7
            </span>
          </li>
        </ul>
      </div>
    </div>

    <!-- Bottom bar -->
    <div
      class="flex flex-col sm:flex-row items-center justify-between gap-3 pt-8"
      style="border-top: 1px solid var(--border);"
    >
      <p class="text-xs" style="color: var(--text-muted);">
        © {currentYear} {site.name}. Todos los derechos reservados.
      </p>
      <a
        href="https://biglee.io"
        target="_blank"
        rel="noopener noreferrer"
        class="text-xs transition-colors duration-200"
        style="color: var(--text-muted);"
      >
        Desarrollado por <span style="color: var(--gold);">biglee.io</span>
      </a>
    </div>
  </div>
</footer>

<style>
  a:hover {
    color: var(--text-primary) !important;
  }
  .social-icon:hover {
    border-color: var(--gold) !important;
    color: var(--gold) !important;
    transform: translateY(-2px);
  }
</style>
